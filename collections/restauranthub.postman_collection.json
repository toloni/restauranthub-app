    {
      "name": "USER-TYPE",
      "item": [
        {
          "name": "get-all-usertype",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Converter a resposta da API em formato JSON",
                  "const responseData = pm.response.json();",
                  "",
                  "// 2. Procurar o objeto que tem a role \"RESTAURANT_OWNER\"",
                  "const ownerType = responseData.content.find(item => item.role === \"RESTAURANT_OWNER\");",
                  "",
                  "// 3. Procurar o objeto que tem a role \"CUSTOMER\"",
                  "const customerType = responseData.content.find(item => item.role === \"CUSTOMER\");",
                  "",
                  "// 4. Salvar os IDs encontrados nas variáveis de ambiente da Collection",
                  "if (ownerType) {",
                  "    pm.collectionVariables.set(\"userTypeOwnerId\", ownerType.id);",
                  "    console.log(\"userTypeOwnerId definido para: \" + ownerType.id);",
                  "}",
                  "",
                  "if (customerType) {",
                  "    pm.collectionVariables.set(\"userTypeCustomerId\", customerType.id);",
                  "    console.log(\"userTypeCustomerId definido para: \" + customerType.id);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
